
config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config globals 'globals'
	option ula_prefix 'fd70:d7eb:51e2::/48'

config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'eth0'

config interface 'lan'
	option proto 'static'
	option netmask '255.255.255.0'
	option ip6assign '60'
	option device 'eth0'
	option ipaddr '192.168.166.244'
	option gateway '192.168.166.1'

config interface 'brlan'
	option proto 'static'
	option device 'br-lan'
	option ipaddr '172.16.3.1'
	option netmask '255.255.255.0'

